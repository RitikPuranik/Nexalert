# ─── Supabase (database + realtime) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Get free key from: https://aistudio.google.com → Get API Key
# Free tier: 15 RPM, 250 RPD — no credit card required
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Firebase Authentication ──────────────────────────────────────────────────
# Client-side config (safe to expose — NEXT_PUBLIC_ prefix)
# Get from: Firebase Console → Project Settings → General → Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Server-side Firebase Admin SDK (NEVER expose these)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Paste the private key exactly as-is from the JSON file (including \n characters)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ─── Sensor Security ──────────────────────────────────────────────────────────
# Shared secret between ESP32 hardware / simulator and this API
# Generate with: openssl rand -hex 32
SENSOR_SECRET=your-sensor-secret-here

# ─── Twilio SMS (optional — alerts still work via in-app if not set) ──────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
